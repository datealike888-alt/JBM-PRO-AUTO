# MySQL/MariaDB connection settings
#
# Production VPS / Docker Compose:
# DB_HOST=db
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-mysql-root-password
# DB_NAME=jbm_pro_auto_prod
# DATABASE_URL=mysql://root:your-mysql-root-password@db:3306/jbm_pro_auto_prod
#
# Windows local Next.js against Docker-mapped MySQL:
# DB_HOST=127.0.0.1
# DB_PORT=3307
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=jbm_pro_auto
# DATABASE_URL=mysql://root:root@127.0.0.1:3307/jbm_pro_auto
#
# Do not hardcode localhost or 127.0.0.1 in production code paths.
DB_HOST=your-production-db-host
DB_PORT=3306
DB_USER=your-production-db-user
DB_PASSWORD=your-production-db-password
DB_NAME=jbm_pro_auto_prod
DATABASE_URL=mysql://user:password@your-production-db-host:3306/jbm_pro_auto_prod

# App URLs
NEXT_PUBLIC_APP_URL=https://your-domain.example
APP_URL=https://your-domain.example

# Session/auth
SESSION_SECRET=change-me-to-a-long-random-secret
SESSION_COOKIE_SECURE=true
VEHICLE_ADMIN_TOKEN=change-me-admin-token
ADMIN_DEFAULT_USERNAME=admin
# Bcrypt hash for the documented initial password. Change it immediately after deploy.
ADMIN_DEFAULT_PASSWORD_HASH=$2b$10$Gm/qbmmeTtZvgnYLBchSHerur2GJhKSRXUZY8xSNwI2pDFUkS7ikW

# Optional local-only phpMyAdmin access on production hosts.
# Use together with: docker compose -f docker-compose.prod.yml --profile admin up -d phpmyadmin
PHPMYADMIN_PORT=8083

