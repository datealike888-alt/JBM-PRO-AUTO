# JBM PRO AUTO environment template. Do not commit .env or .env.production.
# Put real values in the runtime environment or a secret manager only.

# Production-in-Docker can use the Docker MySQL service named db when launched
# from ../docker-compose.yml. In this setup, db is the VPS production database,
# not a browser/client local database. Keep ALLOW_LOCAL_DATABASE=true only for
# this internal Docker host-name flow.
NODE_ENV=development
DATABASE_URL=mysql://<DB_USER>:<DB_PASSWORD>@db:3306/jbm_pro_auto
REQUIRE_EXTERNAL_DATABASE=false
ALLOW_LOCAL_DATABASE=true
DB_HOST=db
DB_PORT=3306
DB_NAME=jbm_pro_auto
DB_USER=
DB_PASSWORD=

APP_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:8080
SESSION_COOKIE_SECURE=false
SESSION_SECRET=
VEHICLE_ADMIN_TOKEN=
GEMINI_API_KEY=

# If this app is deployed outside the compose network, production must use HTTPS,
# a remote external database, and secure cookies.
# External production DATABASE_URL must not use localhost, 127.0.0.1, db, mysql,
# mariadb, jbm-mysql, or root as the app user.
# Production SESSION_SECRET must be supplied at runtime and must be at least 48 characters.
#
# NODE_ENV=production
# DATABASE_URL=mysql://<DB_USER>:<DB_PASSWORD>@<REMOTE_DB_HOST>:3306/<DB_NAME>
# REQUIRE_EXTERNAL_DATABASE=true
# ALLOW_LOCAL_DATABASE=false
# APP_URL=https://your-domain.example
# NEXT_PUBLIC_APP_URL=https://your-domain.example
# SESSION_COOKIE_SECURE=true
# SESSION_SECRET=

# Explicit one-time admin bootstrap script input.
# Do not commit real values. Prefer setting these only in the shell running npm run admin:create.
# ADMIN_USERNAME=
# ADMIN_DISPLAY_NAME=
# ADMIN_PASSWORD=
